# Configuración del Servidor
SERVER_PORT=8080
DB_PATH=./ponches.db
LOG_LEVEL=info

# Información de la Empresa (para reportes)
COMPANY_NAME=Tu Empresa S.R.L.
COMPANY_RNC=1-30-12345-6

# Configuración del Escáner SADP
SADP_TIMEOUT_SECONDS=5

# Opcional: Credenciales por defecto para dispositivos Hikvision descubiertos
# HIKVISION_USERNAME=admin
# HIKVISION_PASSWORD=TuPassword123!
# HIKVISION_PORT=80

# Configuración de Asistencia y Reglas (Valores por defecto)
DEFAULT_SHIFT_START=08:00
DEFAULT_SHIFT_END=17:00
LUNCH_BREAK_MINUTES=60
GRACE_PERIOD_MINUTES=5

# Horas Extras
OVERTIME_MULTIPLIER_SIMPLE=1.5
OVERTIME_MULTIPLIER_DOUBLE=2.0
OVERTIME_MULTIPLIER_TRIPLE=3.0
OVERTIME_THRESHOLD_HOURS=8

# JWT Authentication
JWT_SECRET=cambia-esta-clave-secreta-en-produccion-usa-una-frase-larga
JWT_EXPIRATION_HOURS=24

# LDAP Configuration (Opcional)
# LDAP_HOST=ldap.empresa.com
# LDAP_PORT=389
# LDAP_BASE_DN=dc=empresa,dc=com
# LDAP_BIND_DN=cn=admin,dc=empresa,dc=com
# LDAP_BIND_PASS=tu-contrasena
# LDAP_USER_FILTER=(objectClass=person)
# LDAP_DEPT_FILTER=(objectClass=organizationalUnit)
# LDAP_POS_FILTER=(objectClass=group)
